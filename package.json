{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.11.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^6.0.3",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "firebase": "^12.16.0",
    "lucide-react": "^1.24.0",
    "motion": "^12.23.24",
    "node-domexception": "^2.0.2",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-is": "^19.2.7",
    "recharts": "^3.9.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.23.1",
    "typescript": "~5.8.2",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0"
